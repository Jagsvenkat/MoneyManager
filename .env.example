# Environment Configuration Example
# Copy to .env.local and fill with your values

# GitHub Integration (Optional - for sync feature)
# Generate at https://github.com/settings/tokens
# Requires: repo (full access to private repos)
GITHUB_PAT=your_personal_access_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=private_repo_for_backups

# App Configuration
APP_NAME=Money Manager
APP_VERSION=1.0.0
DEBUG_MODE=false

# Security Settings
# Password requirements (set in app, not overrideable)
MIN_PASSWORD_LENGTH=12
REQUIRE_UPPERCASE=true
REQUIRE_LOWERCASE=true
REQUIRE_NUMBERS=true
REQUIRE_SPECIAL_CHARS=true

# Biometric Settings
ENABLE_BIOMETRIC_UNLOCK=true
BIOMETRIC_FOR_EXPORTS=true
BIOMETRIC_FOR_SYNC=false

# Sync Settings
AUTO_SYNC_ENABLED=false
SYNC_INTERVAL_MINUTES=60
THROTTLE_SYNC_ATTEMPTS=true
SYNC_THROTTLE_SECONDS=300

# Logging
LOG_LEVEL=INFO
LOG_SENSITIVE_DATA=false
LOG_ENCRYPTION_OPERATIONS=false

# Feature Flags
ENABLE_INVESTMENTS=true
ENABLE_LOANS=true
ENABLE_XLSX_EXPORT=true
ENABLE_CSV_EXPORT=true
ENABLE_ENCRYPTED_BACKUP=true
ENABLE_OFFLINE_CHARTS=true
